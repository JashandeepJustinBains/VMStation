---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: jellyfin
  namespace: jellyfin
  labels:
    app.kubernetes.io/name: jellyfin
    app.kubernetes.io/instance: jellyfin
    app.kubernetes.io/version: "{{ jellyfin_version | default('latest') }}"
    app.kubernetes.io/component: media-server
    app.kubernetes.io/part-of: vmstation
spec:
  replicas: {{ jellyfin_replicas | default(2) }}
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxUnavailable: 0
      maxSurge: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: jellyfin
      app.kubernetes.io/instance: jellyfin
  template:
    metadata:
      labels:
        app.kubernetes.io/name: jellyfin
        app.kubernetes.io/instance: jellyfin
        app.kubernetes.io/version: "{{ jellyfin_version | default('latest') }}"
        app.kubernetes.io/component: media-server
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8096"
        prometheus.io/path: "/metrics"
    spec:
      # Anti-affinity to distribute pods across nodes
      affinity:
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
          - weight: 100
            podAffinityTerm:
              labelSelector:
                matchExpressions:
                - key: app.kubernetes.io/name
                  operator: In
                  values:
                  - jellyfin
              topologyKey: kubernetes.io/hostname
      
      # Node selector to prefer compute and storage nodes for media streaming
      nodeSelector:
        # Prefer nodes with sufficient resources for 4K streaming
        kubernetes.io/arch: amd64
      
      tolerations:
      - key: node-role.kubernetes.io/worker
        operator: Equal
        effect: NoSchedule
      
      containers:
      - name: jellyfin
        image: {{ jellyfin_image | default('jellyfin/jellyfin:latest') }}
        imagePullPolicy: Always
        
        # Resource allocation for 4K streaming optimization
        resources:
          requests:
            cpu: {{ jellyfin_cpu_request | default('1000m') }}
            memory: {{ jellyfin_memory_request | default('2Gi') }}
          limits:
            cpu: {{ jellyfin_cpu_limit | default('2000m') }}
            memory: {{ jellyfin_memory_limit | default('4Gi') }}
        
        ports:
        - containerPort: 8096
          name: http
          protocol: TCP
        - containerPort: 8920
          name: https
          protocol: TCP
        - containerPort: 1900
          name: upnp
          protocol: UDP
        - containerPort: 7359
          name: discovery
          protocol: UDP
        
        env:
        - name: JELLYFIN_PublishedServerUrl
          value: "http://{{ jellyfin_external_url | default('192.168.4.61:30096') }}"
        - name: JELLYFIN_CACHE_DIR
          value: "/cache"
        - name: JELLYFIN_CONFIG_DIR
          value: "/config"
        - name: JELLYFIN_DATA_DIR
          value: "/config"
        - name: JELLYFIN_LOG_DIR
          value: "/config/logs"
        # Hardware acceleration environment variables
        - name: JELLYFIN_FFmpeg__probesize
          value: "1G"
        - name: JELLYFIN_FFmpeg__analyzeduration
          value: "200M"
        
        volumeMounts:
        - name: jellyfin-config
          mountPath: /config
        - name: jellyfin-media
          mountPath: /media
          readOnly: true
        - name: jellyfin-cache
          mountPath: /cache
        
        # Health checks for high availability
        livenessProbe:
          httpGet:
            path: /health
            port: http
            scheme: HTTP
          initialDelaySeconds: 60
          periodSeconds: 30
          timeoutSeconds: 10
          successThreshold: 1
          failureThreshold: 3
        
        readinessProbe:
          httpGet:
            path: /health
            port: http
            scheme: HTTP
          initialDelaySeconds: 30
          periodSeconds: 10
          timeoutSeconds: 5
          successThreshold: 1
          failureThreshold: 3
        
        startupProbe:
          httpGet:
            path: /health
            port: http
            scheme: HTTP
          initialDelaySeconds: 10
          periodSeconds: 10
          timeoutSeconds: 5
          successThreshold: 1
          failureThreshold: 30
        
        # Security context for media access
        securityContext:
          runAsUser: 1000
          runAsGroup: 1000
          fsGroup: 1000
          allowPrivilegeEscalation: false
          capabilities:
            drop:
            - ALL
          readOnlyRootFilesystem: false
      
      volumes:
      - name: jellyfin-config
        persistentVolumeClaim:
          claimName: jellyfin-config-pvc
      - name: jellyfin-media
        persistentVolumeClaim:
          claimName: jellyfin-media-pvc
      - name: jellyfin-cache
        emptyDir:
          sizeLimit: {{ jellyfin_cache_size | default('5Gi') }}
      
      restartPolicy: Always
      
      # Priority for media streaming workload
      priorityClassName: system-cluster-critical